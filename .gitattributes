# Normalize line endings to avoid Windows/Unix churn.
* text=auto eol=lf

# Scripts that must keep their platform line endings
*.bat text eol=crlf
*.ps1 text eol=crlf
*.sh  text eol=lf

# Treat these as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.ttf binary
*.woff binary
*.woff2 binary
*.node binary
*.exe binary
