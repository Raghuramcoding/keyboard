# Copy to ../.env (repo root) and edit.   cp deploy/.env.example .env

# Domain whose A/AAAA record points at this server (Caddy gets a cert for it).
TCK_DOMAIN=tck.example.com

# ---- Basic-auth gate ----
# The terminal is a real shell, so do NOT expose T.C.K unauthenticated.
# The username + bcrypt hash live in deploy/Caddyfile (a hash's '$' characters
# can't pass cleanly through Compose env). Generate one:
#   docker run --rm caddy caddy hash-password --plaintext 'your-strong-password'
# and paste it into deploy/Caddyfile.  (Or lock the port down with a firewall.)

# ---- GitHub OAuth (optional — enables the Source Control / Git panel) ----
# Register an OAuth App at github.com/settings/developers with callback:
#   https://tck.example.com/auth/github/callback
TCK_GITHUB_CLIENT_ID=
TCK_GITHUB_CLIENT_SECRET=
TCK_GITHUB_CALLBACK=https://tck.example.com/auth/github/callback
