{
  "name": "claude-code",
  "version": "2.0.0",
  "description": "Claude Code — AI-powered coding environment with Ollama & Claude API support",
  "main": "dist/main.js",
  "scripts": {
    "build": "node build.js",
    "typecheck": "tsc --noEmit",
    "start": "electron .",
    "dev": "concurrently \"node build.js --watch\" \"wait-on dist/main.js && npm:start\"",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "ai",
    "coding",
    "claude",
    "anthropic",
    "ollama",
    "electron",
    "react",
    "monaco-editor"
  ],
  "author": "Raghuramcoding",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raghuramcoding/keyboard.git"
  },
  "bugs": {
    "url": "https://github.com/Raghuramcoding/keyboard/issues"
  },
  "homepage": "https://github.com/Raghuramcoding/keyboard#readme",
  "type": "commonjs",
  "build": {
    "appId": "com.claudecode.app",
    "productName": "Claude Code",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/node-pty/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Claude Code",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/xterm": "^2.0.3",
    "ai": "^6.0.209",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}
